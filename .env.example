# Copy exact values from the CROO dashboard or official deployment docs.
# Blank values intentionally fail closed; no development fallback is used.
# Production endpoints (confirm in current CROO docs before use):
# CROO_API_URL=https://api.croo.network
# CROO_WS_URL=wss://api.croo.network/ws
CROO_API_URL=
CROO_WS_URL=
CROO_SDK_KEY=

# IDs created in the CROO Agent Store.
CAPWITNESS_SERVICE_ID=
CAPWITNESS_AGENT_ID=

# Explicit maximum inner order price in the payment token's units.
CAPWITNESS_MAX_INNER_PRICE=

# Required durable Mastra workflow snapshot store. This deployment accepts file: URLs only.
CAPWITNESS_WORKFLOW_DB_URL=file:./data/capwitness-workflows.db

# Strong random value used only for the operator console.
CAPWITNESS_OPERATOR_TOKEN=

# Optional overrides.
# BASE_RPC_URL=https://mainnet.base.org
# CAPWITNESS_RECEIPT_DIR=/absolute/path/to/capwitness/data/receipts
