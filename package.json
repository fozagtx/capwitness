{
  "name": "capwitness",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "Paid CAP agent that spot-checks another CAP service and returns a bounded evidence receipt.",
  "repository": {
    "type": "git",
    "url": "https://github.com/fozagtx/capwitness"
  },
  "scripts": {
    "dev": "next dev",
    "dev:worker": "tsx watch src/worker/index.ts",
    "worker": "tsx src/worker/index.ts",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "demo:record": "python3 scripts/record_demo.py",
    "live:preflight": "tsx scripts/live-cap-validation.ts preflight",
    "live:prepare": "tsx scripts/live-cap-validation.ts prepare",
    "live:execute": "tsx scripts/live-cap-validation.ts execute",
    "live:preflight:local": "node --env-file=.env.live.local --import tsx scripts/live-cap-validation.ts preflight",
    "live:prepare:local": "node --env-file=.env.live.local --import tsx scripts/live-cap-validation.ts prepare",
    "live:execute:local": "node --env-file=.env.live.local --import tsx scripts/live-cap-validation.ts execute"
  },
  "dependencies": {
    "@croo-network/sdk": "^0.2.1",
    "@iconify/react": "^6.0.2",
    "@mastra/core": "^1.50.1",
    "@mastra/libsql": "^1.15.1",
    "@radix-ui/react-slot": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "postcss": "8.5.17"
  }
}
